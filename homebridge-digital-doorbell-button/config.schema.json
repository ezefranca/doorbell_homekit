{
  "pluginAlias": "DigitalDoorbellBridge",
  "pluginType": "platform",
  "singular": true,
  "strictValidation": false,
  "schema": {
    "type": "object",
    "required": [
      "name"
    ],
    "additionalProperties": false,
    "properties": {
      "name": {
        "title": "Base Name",
        "type": "string",
        "default": "Digital Doorbell"
      },
      "buttonName": {
        "title": "Button Accessory Name",
        "type": "string",
        "default": "Digital Doorbell Button"
      },
      "doorbellName": {
        "title": "Doorbell Accessory Name",
        "type": "string",
        "default": "Digital Doorbell Doorbell"
      },
      "manufacturer": {
        "title": "Manufacturer",
        "type": "string",
        "default": "Custom"
      },
      "model": {
        "title": "Model",
        "type": "string",
        "default": "Virtual Doorbell Button"
      },
      "serialBase": {
        "title": "Serial Base",
        "type": "string",
        "default": "digital-doorbell"
      },
      "autoOffMilliseconds": {
        "title": "Button Auto-Off Milliseconds",
        "type": "integer",
        "default": 1000,
        "minimum": 100
      },
      "webhookEnabled": {
        "title": "Enable Webhook",
        "type": "boolean",
        "default": true
      },
      "webhookHost": {
        "title": "Webhook Host",
        "type": "string",
        "default": "0.0.0.0"
      },
      "webhookPort": {
        "title": "Webhook Port",
        "type": "integer",
        "default": 51849,
        "minimum": 1,
        "maximum": 65535
      },
      "webhookPath": {
        "title": "Webhook Path",
        "type": "string",
        "default": "/doorbell/ring"
      }
    }
  }
}
